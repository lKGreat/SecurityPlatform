{
  "key": "system.roles",
  "title": "角色管理",
  "description": "通过 AMIS CRUD 统一管理角色与菜单/权限分配",
  "tableKey": "system.roles",
  "schema": {
    "type": "page",
    "title": "角色管理",
    "body": [
      {
        "type": "crud",
        "name": "roles-crud",
        "syncLocation": false,
        "perPage": 20,
        "api": {
          "url": "/roles?pageIndex=${page}&pageSize=${perPage}&keyword=${keyword}&isSystem=${isSystem}",
          "method": "get",
          "adaptor": "const payloadData = payload?.data ?? { items: [], total: 0 }; return { status: 0, msg: payload?.message ?? 'OK', data: payloadData };"
        },
        "filter": [
          { "type": "input-text", "name": "keyword", "label": "关键字", "placeholder": "名称/编码", "clearable": true },
          {
            "type": "select",
            "name": "isSystem",
            "label": "来源",
            "options": [
              { "label": "全部", "value": "" },
              { "label": "系统角色", "value": "true" },
              { "label": "自定义角色", "value": "false" }
            ]
          }
        ],
        "headerToolbar": [
          {
            "type": "button",
            "label": "新增角色",
            "level": "primary",
            "actionType": "dialog",
            "dialog": {
              "title": "新增角色",
              "body": [
                { "type": "input-text", "name": "name", "label": "名称", "required": true },
                { "type": "input-text", "name": "code", "label": "编码", "required": true },
                { "type": "textarea", "name": "description", "label": "描述", "rows": 3 }
              ],
              "actions": [
                {
                  "type": "button",
                  "label": "保存",
                  "level": "primary",
                  "actionType": "ajax",
                  "api": {
                    "url": "/roles",
                    "method": "post",
                    "adaptor": "return { status: payload?.success ? 0 : 1, msg: payload?.message ?? '操作完成', data: payload?.data };"
                  }
                }
              ]
            }
          },
          "reload"
        ],
        "columns": [
          { "name": "name", "label": "名称", "sortable": true },
          { "name": "code", "label": "编码" },
          { "name": "description", "label": "描述", "tpl": "<span>${description || '-'}</span>" },
          {
            "name": "isSystem",
            "label": "类型",
            "type": "tpl",
            "tpl": "<span>${isSystem ? '系统' : '自定义'}</span>"
          },
          {
            "type": "operation",
            "label": "操作",
            "buttons": [
              {
                "label": "编辑",
                "level": "link",
                "actionType": "dialog",
                "dialog": {
                  "title": "编辑角色",
                  "initApi": "/roles/${id}",
                  "body": [
                    { "type": "input-text", "name": "name", "label": "名称", "required": true },
                    { "type": "input-text", "name": "code", "label": "编码", "disabled": true },
                    { "type": "textarea", "name": "description", "label": "描述", "rows": 3 }
                  ],
                  "actions": [
                    {
                      "type": "button",
                      "label": "保存",
                      "level": "primary",
                      "actionType": "ajax",
                      "api": {
                        "url": "/roles/${id}",
                        "method": "put",
                        "adaptor": "return { status: payload?.success ? 0 : 1, msg: payload?.message ?? '更新完成' };"
                      }
                    }
                  ]
                }
              },
              {
                "label": "删除",
                "level": "link",
                "actionType": "ajax",
                "confirmText": "确认删除该角色？",
                "api": {
                  "url": "/roles/${id}",
                  "method": "delete",
                  "adaptor": "return { status: payload?.success ? 0 : 1, msg: payload?.message ?? '删除完成' };"
                }
              },
              {
                "label": "权限",
                "level": "link",
                "actionType": "dialog",
                "dialog": {
                  "title": "分配权限",
                  "body": [
                    {
                      "type": "select",
                      "name": "permissionIds",
                      "label": "权限",
                      "mode": "multiple",
                      "searchable": true,
                      "source": {
                        "url": "/permissions?pageIndex=1&pageSize=20&keyword=${term}",
                        "method": "get",
                        "adaptor": "const list = payload?.data?.items ?? []; return { status: 0, msg: payload?.message ?? 'OK', data: list };"
                      },
                      "valueField": "id",
                      "labelField": "name"
                    }
                  ],
                  "actions": [
                    {
                      "type": "button",
                      "label": "保存",
                      "level": "primary",
                      "actionType": "ajax",
                      "api": {
                        "url": "/roles/${id}/permissions",
                        "method": "put",
                        "adaptor": "return { status: payload?.success ? 0 : 1, msg: payload?.message ?? '保存完成' };"
                      }
                    }
                  ]
                }
              },
              {
                "label": "菜单",
                "level": "link",
                "actionType": "dialog",
                "dialog": {
                  "title": "分配菜单",
                  "body": [
                    {
                      "type": "select",
                      "name": "menuIds",
                      "label": "菜单",
                      "mode": "multiple",
                      "searchable": true,
                      "source": {
                        "url": "/menus?pageIndex=1&pageSize=20&keyword=${term}",
                        "method": "get",
                        "adaptor": "const list = payload?.data?.items ?? []; return { status: 0, msg: payload?.message ?? 'OK', data: list };"
                      },
                      "valueField": "id",
                      "labelField": "name"
                    }
                  ],
                  "actions": [
                    {
                      "type": "button",
                      "label": "保存",
                      "level": "primary",
                      "actionType": "ajax",
                      "api": {
                        "url": "/roles/${id}/menus",
                        "method": "put",
                        "adaptor": "return { status: payload?.success ? 0 : 1, msg: payload?.message ?? '保存完成' };"
                      }
                    }
                  ]
                }
              }
            ]
          }
        ]
      }
    ]
  }
}
