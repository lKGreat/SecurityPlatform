{
  "key": "system.users",
  "title": "员工管理",
  "description": "通过 AMIS CRUD 快速操作员工信息、角色/部门/岗位",
  "tableKey": "system.users",
  "schema": {
    "type": "page",
    "title": "员工管理",
    "body": [
      {
        "type": "crud",
        "name": "users-crud",
        "syncLocation": false,
        "api": {
          "url": "/users?pageIndex=${page}&pageSize=${perPage}&keyword=${keyword}",
          "method": "get",
          "adaptor": "const payloadData = payload?.data ?? { items: [], total: 0 }; return { status: 0, msg: payload?.message ?? 'OK', data: payloadData };"
        },
        "perPage": 20,
        "filter": [
          {
            "type": "input-text",
            "name": "keyword",
            "placeholder": "用户名/姓名/邮箱",
            "clearable": true,
            "label": "关键字"
          }
        ],
        "headerToolbar": [
          {
            "type": "button",
            "label": "新增员工",
            "level": "primary",
            "actionType": "dialog",
            "dialog": {
              "title": "新增员工",
              "size": "lg",
              "body": [
                { "type": "input-text", "name": "username", "label": "用户名", "required": true },
                { "type": "input-password", "name": "password", "label": "密码", "required": true },
                { "type": "input-text", "name": "displayName", "label": "姓名", "required": true },
                { "type": "input-text", "name": "email", "label": "邮箱" },
                { "type": "input-text", "name": "phoneNumber", "label": "手机号" },
                { "type": "switch", "name": "isActive", "label": "启用", "trueValue": true, "falseValue": false },
                {
                  "type": "select",
                  "name": "roleIds",
                  "label": "角色",
                  "mode": "multiple",
                  "searchable": true,
                  "source": {
                    "url": "/roles?pageIndex=1&pageSize=20&keyword=${term}",
                    "method": "get",
                    "adaptor": "const list = payload?.data?.items ?? []; return { status: 0, msg: payload?.message ?? 'OK', data: list };"
                  },
                  "valueField": "id",
                  "labelField": "name"
                },
                {
                  "type": "select",
                  "name": "departmentIds",
                  "label": "部门",
                  "mode": "multiple",
                  "searchable": true,
                  "source": {
                    "url": "/departments?pageIndex=1&pageSize=20&keyword=${term}",
                    "method": "get",
                    "adaptor": "const list = payload?.data?.items ?? []; return { status: 0, msg: payload?.message ?? 'OK', data: list };"
                  },
                  "valueField": "id",
                  "labelField": "name"
                },
                {
                  "type": "select",
                  "name": "positionIds",
                  "label": "职位",
                  "mode": "multiple",
                  "searchable": true,
                  "source": {
                    "url": "/positions?pageIndex=1&pageSize=20&keyword=${term}",
                    "method": "get",
                    "adaptor": "const list = payload?.data?.items ?? []; return { status: 0, msg: payload?.message ?? 'OK', data: list };"
                  },
                  "valueField": "id",
                  "labelField": "name"
                }
              ],
              "actions": [
                {
                  "type": "button",
                  "label": "保存",
                  "level": "primary",
                  "actionType": "ajax",
                  "api": {
                    "url": "/users",
                    "method": "post",
                    "adaptor": "return { status: payload?.success ? 0 : 1, msg: payload?.message ?? '操作完成', data: payload?.data };"
                  }
                }
              ]
            }
          },
          "reload"
        ],
        "columns": [
          { "name": "username", "label": "用户名", "sortable": true },
          { "name": "displayName", "label": "姓名" },
          { "name": "email", "label": "邮箱" },
          { "name": "phoneNumber", "label": "手机号" },
          {
            "name": "isActive",
            "label": "状态",
            "type": "tpl",
            "tpl": "<span>${isActive ? '启用' : '停用'}</span>"
          },
          { "name": "lastLoginAt", "label": "最近登录", "sortable": true },
          {
            "type": "operation",
            "label": "操作",
            "buttons": [
              {
                "label": "编辑",
                "level": "link",
                "actionType": "dialog",
                "dialog": {
                  "title": "编辑员工",
                  "size": "lg",
                  "initApi": "/users/${id}",
                  "body": [
                    { "type": "input-text", "name": "username", "label": "用户名", "disabled": true },
                    { "type": "input-text", "name": "displayName", "label": "姓名", "required": true },
                    { "type": "input-text", "name": "email", "label": "邮箱" },
                    { "type": "input-text", "name": "phoneNumber", "label": "手机号" },
                    { "type": "switch", "name": "isActive", "label": "启用", "trueValue": true, "falseValue": false }
                  ],
                  "actions": [
                    {
                      "type": "button",
                      "label": "保存",
                      "level": "primary",
                      "actionType": "ajax",
                      "api": {
                        "url": "/users/${id}",
                        "method": "put",
                        "adaptor": "return { status: payload?.success ? 0 : 1, msg: payload?.message ?? '更新完成', data: payload?.data };"
                      }
                    }
                  ]
                }
              },
              {
                "label": "删除",
                "level": "link",
                "actionType": "ajax",
                "confirmText": "确认删除该员工？",
                "api": {
                  "url": "/users/${id}",
                  "method": "delete",
                  "adaptor": "return { status: payload?.success ? 0 : 1, msg: payload?.message ?? '删除完成' };"
                }
              },
              {
                "label": "设置角色",
                "level": "link",
                "actionType": "dialog",
                "dialog": {
                  "title": "设置角色",
                  "body": [
                    {
                      "type": "select",
                      "name": "roleIds",
                      "label": "角色",
                      "mode": "multiple",
                      "searchable": true,
                      "clearable": true,
                      "source": {
                        "url": "/roles?pageIndex=1&pageSize=20&keyword=${term}",
                        "method": "get",
                        "adaptor": "const list = payload?.data?.items ?? []; return { status: 0, msg: payload?.message ?? 'OK', data: list };"
                      },
                      "valueField": "id",
                      "labelField": "name"
                    }
                  ],
                  "actions": [
                    {
                      "type": "button",
                      "label": "保存",
                      "level": "primary",
                      "actionType": "ajax",
                      "api": {
                        "url": "/users/${id}/roles",
                        "method": "put",
                        "adaptor": "return { status: payload?.success ? 0 : 1, msg: payload?.message ?? '保存完成', data: payload?.data };"
                      }
                    }
                  ]
                }
              },
              {
                "label": "设置部门",
                "level": "link",
                "actionType": "dialog",
                "dialog": {
                  "title": "设置部门",
                  "body": [
                    {
                      "type": "select",
                      "name": "departmentIds",
                      "label": "部门",
                      "mode": "multiple",
                      "searchable": true,
                      "clearable": true,
                      "source": {
                        "url": "/departments?pageIndex=1&pageSize=20&keyword=${term}",
                        "method": "get",
                        "adaptor": "const list = payload?.data?.items ?? []; return { status: 0, msg: payload?.message ?? 'OK', data: list };"
                      },
                      "valueField": "id",
                      "labelField": "name"
                    }
                  ],
                  "actions": [
                    {
                      "type": "button",
                      "label": "保存",
                      "level": "primary",
                      "actionType": "ajax",
                      "api": {
                        "url": "/users/${id}/departments",
                        "method": "put",
                        "adaptor": "return { status: payload?.success ? 0 : 1, msg: payload?.message ?? '保存完成' };"
                      }
                    }
                  ]
                }
              },
              {
                "label": "设置岗位",
                "level": "link",
                "actionType": "dialog",
                "dialog": {
                  "title": "设置岗位",
                  "body": [
                    {
                      "type": "select",
                      "name": "positionIds",
                      "label": "岗位",
                      "mode": "multiple",
                      "searchable": true,
                      "clearable": true,
                      "source": {
                        "url": "/positions?pageIndex=1&pageSize=20&keyword=${term}",
                        "method": "get",
                        "adaptor": "const list = payload?.data?.items ?? []; return { status: 0, msg: payload?.message ?? 'OK', data: list };"
                      },
                      "valueField": "id",
                      "labelField": "name"
                    }
                  ],
                  "actions": [
                    {
                      "type": "button",
                      "label": "保存",
                      "level": "primary",
                      "actionType": "ajax",
                      "api": {
                        "url": "/users/${id}/positions",
                        "method": "put",
                        "adaptor": "return { status: payload?.success ? 0 : 1, msg: payload?.message ?? '保存完成' };"
                      }
                    }
                  ]
                }
              }
            ]
          }
        ]
      }
    ]
  }
}
