{
  "key": "system.permissions",
  "title": "权限管理",
  "description": "通过 AMIS 管理接口层权限码",
  "tableKey": "system.permissions",
  "schema": {
    "type": "page",
    "title": "权限管理",
    "body": [
      {
        "type": "crud",
        "name": "permissions-crud",
        "syncLocation": false,
        "perPage": 20,
        "api": {
          "url": "/permissions?pageIndex=${page}&pageSize=${perPage}&keyword=${keyword}&type=${type}",
          "method": "get",
          "adaptor": "const payloadData = payload?.data ?? { items: [], total: 0 }; return { status: 0, msg: payload?.message ?? 'OK', data: payloadData };"
        },
        "filter": [
          { "type": "input-text", "name": "keyword", "label": "关键字", "placeholder": "名称/编码", "clearable": true },
          {
            "type": "select",
            "name": "type",
            "label": "类型",
            "options": [
              { "label": "全部", "value": "" },
              { "label": "API", "value": "Api" },
              { "label": "菜单", "value": "Menu" }
            ]
          }
        ],
        "headerToolbar": [
          {
            "type": "button",
            "label": "新增权限",
            "level": "primary",
            "actionType": "dialog",
            "dialog": {
              "title": "新增权限",
              "body": [
                { "type": "input-text", "name": "name", "label": "名称", "required": true },
                { "type": "input-text", "name": "code", "label": "编码", "required": true },
                {
                  "type": "select",
                  "name": "type",
                  "label": "类型",
                  "options": [
                    { "label": "API", "value": "Api" },
                    { "label": "菜单", "value": "Menu" }
                  ],
                  "required": true
                },
                { "type": "textarea", "name": "description", "label": "描述", "rows": 3 }
              ],
              "actions": [
                {
                  "type": "button",
                  "label": "保存",
                  "level": "primary",
                  "actionType": "ajax",
                  "api": {
                    "url": "/permissions",
                    "method": "post",
                    "adaptor": "return { status: payload?.success ? 0 : 1, msg: payload?.message ?? '操作完成', data: payload?.data };"
                  }
                }
              ]
            }
          },
          "reload"
        ],
        "columns": [
          { "name": "name", "label": "名称" },
          { "name": "code", "label": "编码" },
          { "name": "type", "label": "类型" },
          { "name": "description", "label": "描述", "tpl": "<span>${description || '-'}</span>" },
          {
            "type": "operation",
            "label": "操作",
            "buttons": [
              {
                "label": "编辑",
                "level": "link",
                "actionType": "dialog",
                "dialog": {
                  "title": "编辑权限",
                  "initApi": "/permissions/${id}",
                  "body": [
                    { "type": "input-text", "name": "name", "label": "名称", "required": true },
                    { "type": "input-text", "name": "code", "label": "编码", "disabled": true },
                    {
                      "type": "select",
                      "name": "type",
                      "label": "类型",
                      "options": [
                        { "label": "API", "value": "Api" },
                        { "label": "菜单", "value": "Menu" }
                      ],
                      "required": true
                    },
                    { "type": "textarea", "name": "description", "label": "描述", "rows": 3 }
                  ],
                  "actions": [
                    {
                      "type": "button",
                      "label": "保存",
                      "level": "primary",
                      "actionType": "ajax",
                      "api": {
                        "url": "/permissions/${id}",
                        "method": "put",
                        "adaptor": "return { status: payload?.success ? 0 : 1, msg: payload?.message ?? '更新完成' };"
                      }
                    }
                  ]
                }
              },
              {
                "label": "提示",
                "level": "link",
                "actionType": "dialog",
                "dialog": {
                  "title": "说明",
                  "body": "当前版本未开放权限删除接口，如需删除请走配置流程。"
                }
              }
            ]
          }
        ]
      }
    ]
  }
}
