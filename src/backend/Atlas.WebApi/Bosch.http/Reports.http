@baseUrl = http://localhost:5000
@tenantId = 00000000-0000-0000-0000-000000000001
@username = admin
@password = P@ssw0rd!

### 登录
# @name login
POST {{baseUrl}}/api/v1/auth/token
Content-Type: application/json
X-Tenant-Id: {{tenantId}}

{
  "username": "{{username}}",
  "password": "{{password}}"
}

###
@accessToken = {{login.response.body.$.data.accessToken}}

### 获取 CSRF Token
# @name antiforgery
GET {{baseUrl}}/api/v1/secure/antiforgery
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

###
@csrfToken = {{antiforgery.response.body.$.data.token}}

### 报表列表（分页）
GET {{baseUrl}}/api/v1/reports?pageIndex=1&pageSize=20&keyword=
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### 创建报表
# @name createReport
POST {{baseUrl}}/api/v1/reports
Content-Type: application/json
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Idempotency-Key: {{$guid}}
X-CSRF-TOKEN: {{csrfToken}}

{
  "name": "资产分布报表",
  "description": "按资产类型统计分布",
  "category": "Security",
  "configJson": "{\"type\":\"bar\",\"xField\":\"assetType\",\"yField\":\"count\"}",
  "dataSourceJson": "{\"source\":\"assets\"}"
}

###
@reportId = {{createReport.response.body.$.data.id}}

### 报表详情
GET {{baseUrl}}/api/v1/reports/{{reportId}}
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}

### 更新报表
PUT {{baseUrl}}/api/v1/reports/{{reportId}}
Content-Type: application/json
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Idempotency-Key: {{$guid}}
X-CSRF-TOKEN: {{csrfToken}}

{
  "name": "资产分布报表（更新）",
  "description": "按资产类型统计分布（更新）",
  "category": "Security",
  "configJson": "{\"type\":\"pie\",\"angleField\":\"count\",\"colorField\":\"assetType\"}",
  "dataSourceJson": "{\"source\":\"assets\"}",
  "printTemplateJson": "{\"title\":\"资产报表\"}"
}

### 删除报表
DELETE {{baseUrl}}/api/v1/reports/{{reportId}}
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
Idempotency-Key: {{$guid}}
X-CSRF-TOKEN: {{csrfToken}}

### 安全负例：创建报表缺少幂等键（预期 400）
POST {{baseUrl}}/api/v1/reports
Content-Type: application/json
Authorization: Bearer {{accessToken}}
X-Tenant-Id: {{tenantId}}
X-CSRF-TOKEN: {{csrfToken}}

{
  "name": "幂等负例报表",
  "description": "缺少幂等键",
  "category": "Security",
  "configJson": "{}"
}
